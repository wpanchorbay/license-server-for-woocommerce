---
import Icon from './Icon.astro';

interface Props {
	icon?: string;
	title: string;
	href?: string;
}

const { icon, title, href } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag class:list={['license-card-link', href && 'is-link']} href={href}>
	<article class="license-card sl-flex">
		<p class="title sl-flex">
			{icon && <span class="icon-shell"><Icon name={icon} class="icon" size="1.1em" /></span>}
			<span set:html={title} />
		</p>
		<div class="body"><slot /></div>
	</article>
</Tag>

<style>
	@layer starlight.components {
		.license-card-link {
			display: block;
			height: 100%;
			color: inherit;
			text-decoration: none;
		}

		.license-card-link:where(:hover, :focus-visible) {
			text-decoration: none;
		}

		.license-card {
			--license-card-accent: #5865f2;
			position: relative;
			overflow: hidden;
			height: 100%;
			border: 1px solid color-mix(in srgb, var(--license-card-accent) 20%, var(--sl-color-hairline));
			border-radius: 1.1rem;
			background:
				radial-gradient(circle at top right,
					color-mix(in srgb, var(--license-card-accent) 18%, transparent) 0%,
					transparent 34%),
				linear-gradient(180deg,
					color-mix(in srgb, var(--sl-color-bg-nav) 72%, white 28%) 0%,
					var(--sl-color-bg) 100%);
			padding: clamp(1.1rem, calc(0.7rem + 1.8vw), 1.75rem);
			flex-direction: column;
			gap: 0.85rem;
			box-shadow:
				0 1px 0 color-mix(in srgb, #fff 70%, transparent) inset,
				0 16px 36px color-mix(in srgb, var(--license-card-accent) 10%, transparent);
			transition:
				transform 180ms ease,
				border-color 180ms ease,
				box-shadow 180ms ease,
				background 180ms ease;
			will-change: transform;
		}

		.license-card::before {
			content: '';
			position: absolute;
			inset: 0 auto 0 0;
			width: 0.3rem;
			background: linear-gradient(180deg, var(--license-card-accent) 0%, color-mix(in srgb, var(--license-card-accent) 38%, white) 100%);
		}

		.license-card:nth-child(4n + 2) {
			--license-card-accent: #0f9d8a;
		}

		.license-card:nth-child(4n + 3) {
			--license-card-accent: #d97706;
		}

		.license-card:nth-child(4n + 4) {
			--license-card-accent: #d9485f;
		}

		.license-card-link.is-link:where(:hover, :focus-visible) .license-card {
			transform: translateY(-3px);
			border-color: color-mix(in srgb, var(--license-card-accent) 38%, var(--sl-color-hairline));
			box-shadow:
				0 1px 0 color-mix(in srgb, #fff 70%, transparent) inset,
				0 20px 40px color-mix(in srgb, var(--license-card-accent) 14%, transparent);
		}

		.license-card-link.is-link:focus-visible {
			outline: none;
		}

		.license-card-link.is-link:focus-visible .license-card {
			box-shadow:
				0 0 0 3px color-mix(in srgb, var(--license-card-accent) 22%, transparent),
				0 0 0 1px color-mix(in srgb, var(--license-card-accent) 48%, transparent),
				0 20px 40px color-mix(in srgb, var(--license-card-accent) 14%, transparent);
		}

		.title {
			margin: 0;
			gap: 0.85rem;
			align-items: center;
			font-size: clamp(1.08rem, 0.98rem + 0.3vw, 1.22rem);
			font-weight: 700;
			line-height: 1.2;
			color: var(--sl-color-white);
		}

		.icon-shell {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 2.25rem;
			height: 2.25rem;
			border-radius: 0.8rem;
			background: color-mix(in srgb, var(--license-card-accent) 14%, white);
			border: 1px solid color-mix(in srgb, var(--license-card-accent) 30%, transparent);
			color: var(--license-card-accent);
			box-shadow: 0 8px 18px color-mix(in srgb, var(--license-card-accent) 18%, transparent);
		}

		.body {
			margin: 0;
			color: var(--sl-color-gray-2);
			font-size: var(--sl-text-body);
			line-height: 1.65;
		}
	}
</style>
