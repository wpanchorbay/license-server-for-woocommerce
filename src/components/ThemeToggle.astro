---
---

<div class="theme-toggle-footer-wrapper">
	<button id="footer-theme-toggle" class="theme-toggle-footer" aria-label="Toggle dark mode">
		<span class="icon sun-icon">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
		</span>
		<span class="icon moon-icon">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
		</span>
		<span class="theme-toggle-text">Mode</span>
	</button>
</div>

<style>
	.theme-toggle-footer-wrapper {
		display: flex;
		justify-content: center;
		margin-top: 1.5rem;
	}

	.theme-toggle-footer {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 14px;
		border-radius: 20px;
		background-color: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-hairline);
		color: var(--sl-color-gray-2);
		font-size: 13px;
		font-weight: 500;
		transition: all 0.25s;
		cursor: pointer;
		line-height: 1;
	}

	.theme-toggle-footer:hover {
		background-color: var(--sl-color-gray-5);
		color: var(--sl-color-accent-high);
		border-color: var(--sl-color-accent);
	}

	.icon {
		display: none;
		align-items: center;
		justify-content: center;
	}

	:root[data-theme='dark'] .sun-icon {
		display: flex;
	}

	:root[data-theme='light'] .moon-icon {
		display: flex;
	}

	.theme-toggle-text {
		line-height: 1;
	}
</style>

<script>
	const toggle = document.getElementById('footer-theme-toggle');
	const text = toggle?.querySelector('.theme-toggle-text');

	const updateUI = () => {
		const isDark = document.documentElement.dataset.theme === 'dark';
		if (text) {
			text.textContent = `${isDark ? 'Light' : 'Dark'} Mode`;
		}
	};

	toggle?.addEventListener('click', () => {
		const theme = document.documentElement.dataset.theme;
		const newTheme = theme === 'dark' ? 'light' : 'dark';
		
		// Update Starlight theme
		document.documentElement.dataset.theme = newTheme;
		localStorage.setItem('starlight-theme', newTheme);
		
		updateUI();
		
		// Trigger a custom event for any other components that might care
		window.dispatchEvent(new CustomEvent('starlight-theme-changed', { detail: { theme: newTheme } }));
	});

	// Initial UI update
	updateUI();
	
	// Listen for theme changes from other toggles (e.g. Starlight's built-in one)
	const observer = new MutationObserver((mutations) => {
		mutations.forEach((mutation) => {
			if (mutation.attributeName === 'data-theme') {
				updateUI();
			}
		});
	});
	
	observer.observe(document.documentElement, { attributes: true });
</script>
